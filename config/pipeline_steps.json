{
  "steps": [
    {
      "key": "expand_seed_catalog",
      "description": "Expand Hyderabad seed catalog with same-brand pairs by category quota",
      "command": [
        "scripts/cleaning/expand_pair_seed_catalog.py",
        "--city",
        "Hyderabad",
        "--fallback-city",
        "Tokyo",
        "--target-per-category",
        "10",
        "--write"
      ]
    },
    {
      "key": "reset_outputs",
      "description": "Reset prior generated raw/clean outputs before scraping",
      "command": [
        "scripts/pipeline/reset_outputs.py",
        "--clear-url-cache"
      ]
    },
    {
      "key": "scrape_amazon_in",
      "description": "Scrape Amazon India observations",
      "command": [
        "scripts/scraping/scrape_amazon_india.py",
        "--browser-mode"
      ]
    },
    {
      "key": "scrape_bigbasket",
      "description": "Scrape BigBasket observations",
      "command": [
        "scripts/scraping/scrape_bigbasket.py",
        "--browser-mode",
        "--headful",
        "--user-data-dir",
        "/tmp/pink_tax_chrome_profile"
      ]
    },
    {
      "key": "scrape_flipkart",
      "description": "Scrape Flipkart observations",
      "command": [
        "scripts/scraping/scrape_flipkart.py",
        "--browser-mode",
        "--headful",
        "--user-data-dir",
        "/tmp/pink_tax_chrome_profile"
      ]
    },
    {
      "key": "scrape_amazon_jp",
      "description": "Scrape Amazon Japan observations",
      "command": [
        "scripts/scraping/scrape_amazon_japan.py",
        "--browser-mode"
      ]
    },
    {
      "key": "scrape_rakuten_jp",
      "description": "Scrape Rakuten Japan observations",
      "optional": true,
      "command": [
        "scripts/scraping/scrape_rakuten_japan.py",
        "--browser-mode"
      ]
    },
    {
      "key": "scrape_matsumoto",
      "description": "Scrape Matsumoto Kiyoshi observations",
      "optional": true,
      "command": [
        "scripts/scraping/scrape_matsumoto_kiyoshi.py",
        "--browser-mode"
      ]
    },
    {
      "key": "build_observations",
      "description": "Build real-only observations from current scrape outputs",
      "command": [
        "scripts/cleaning/build_pair_observations.py",
        "--replace-only",
        "--min-output-rows",
        "0"
      ]
    },
    {
      "key": "clean_pairs",
      "description": "Build cleaned dataset with hybrid gender labeling",
      "command": [
        "scripts/cleaning/generate_pairs_dataset.py",
        "--model-name",
        "MoritzLaurer/mDeBERTa-v3-base-mnli-xnli",
        "--model-threshold",
        "0.60"
      ]
    },
    {
      "key": "clean_finalize",
      "description": "Remove duplicates, missing critical rows, and extreme outliers",
      "command": [
        "scripts/cleaning/clean_pairs_dataset.py"
      ]
    },
    {
      "key": "clean_quality",
      "description": "Build data quality summary",
      "command": [
        "scripts/cleaning/build_quality_queue.py"
      ]
    },
    {
      "key": "clean_enrich",
      "description": "Enrich ingredients from Open Beauty Facts",
      "command": [
        "scripts/cleaning/enrich_openbeautyfacts.py"
      ]
    }
  ]
}
